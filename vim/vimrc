set fileencodings=utf8,cp1251

set undofile

set tabstop=4 softtabstop=0 expandtab shiftwidth=4 smarttab

" Search
set hlsearch
set ignorecase
set smartcase

" Terminal
if has('unix')
    set clipboard=unnamedplus
else
    set clipboard=unnamed
endif
set termguicolors
set lazyredraw
set ttyfast


" Mappings
imap fj <Esc>
nnoremap <C-s> :w<CR>
